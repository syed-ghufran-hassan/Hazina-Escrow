# ─────────────────────────────────────────────
# Hazina Escrow — Frontend Environment Variables
# Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Base URL of the backend API (e.g. http://localhost:3001)
# Required. Omission causes a startup error.
VITE_API_URL=http://localhost:3001

# API Key used for backend authentication (e.g. for creating datasets)
# Required. Must match the API_KEY set in the backend .env.
VITE_API_KEY=your_api_key_here

# Optional: enable the Query Modal demo-mode checkbox for local/admin testing only.
# Leave unset or set to false in production builds.
VITE_ENABLE_DEMO_MODE=false
