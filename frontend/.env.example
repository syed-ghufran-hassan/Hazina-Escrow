# ─────────────────────────────────────────────
# Hazina Escrow — Frontend Environment Variables
# Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# Base URL of the backend API (e.g. http://localhost:3001)
# Required. Omission causes a startup error.
VITE_API_URL=http://localhost:3001

# API Key used for backend authentication (e.g. for creating datasets)
# Required. Must match the API_KEY set in the backend .env.
VITE_API_KEY=your_api_key_here

# Stellar network to use for payments: 'testnet' or 'public' (mainnet)
# Optional. Defaults to 'testnet' if not set.
VITE_STELLAR_NETWORK=testnet

# Optional override for the USDC asset issuer address on Stellar.
# If not set, defaults to the official Circle USDC issuer for the chosen network.
# Testnet: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet: GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
VITE_USDC_ISSUER=

# Maximum number of concurrent API requests to allow at once.
# Optional. Defaults to 8.
VITE_MAX_CONCURRENT_REQUESTS=8
