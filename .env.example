# ─────────────────────────────────────────────
# Hazina Escrow — Backend Environment Variables
# Copy this file to backend/.env and fill in values.
# NEVER commit your real .env file.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3001
# The URL of the running frontend (used for CORS).
FRONTEND_URL=http://localhost:5173

# ── API Keys ──────────────────────────────────
# Must match VITE_API_KEY in frontend/.env
API_KEY=your_dataset_creation_key
# Used for administrative actions like backups
ADMIN_API_KEY=your_admin_key
# Used for signing seller dashboard JWT tokens
SELLER_JWT_SECRET=your_jwt_secret_here
# Shared secret for verifying incoming payment webhooks
PAYMENT_WEBHOOK_SECRET=your_webhook_verification_secret_here

# ── Database ───────────────────────────────────
# SQLite (default): file:./sqlite.db
DATABASE_URL=file:./sqlite.db

# ── Anthropic / Claude ─────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...
# Default Claude model for summaries and health checks.
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Stellar Network ────────────────────────────
# "testnet" or "mainnet" — defaults to testnet if unset.
STELLAR_NETWORK=testnet

# ── Escrow & Agent ─────────────────────────────
# The Stellar G... address that receives buyer payments.
ESCROW_WALLET=G...
# The secret key (S...) for the autonomous Research Agent's wallet.
AGENT_WALLET_SECRET=S...
# The deployed contract ID on testnet
ESCROW_CONTRACT_ID=CCPG2CSL6WDUA2IFUDHFN5SCJQUTFCLFKMTARALQ5RWGB2RGG345HEEH

# ── USDC Asset ─────────────────────────────────
# Testnet USDC issuer  : GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet USDC issuer  : GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── Platform Fee ───────────────────────────────
# Basis points taken by the platform on each sale (500 = 5%).
PLATFORM_FEE_BPS=500
